#version 450
layout(local_size_x = 256) in;

layout(std430, binding = 7) buffer Field {
    float field[]; // linear array of GRID_X*GRID_Y*GRID_Z floats
};

layout(push_constant) uniform FieldParams {
    uint fieldSize; // element count
} params;

void main() {
    uint idx = gl_GlobalInvocationID.x;
    if (idx >= params.fieldSize) return;
    field[idx] = 0.0;
}

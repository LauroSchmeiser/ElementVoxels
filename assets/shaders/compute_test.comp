#version 430
layout (local_size_x = 1) in;
struct OutVertex { vec4 pos; vec4 normal; vec4 color; };
layout(std430, binding = 4) buffer Triangles { OutVertex verts[]; };
layout(std430, binding = 3) buffer Counter { uint vertexCounter; };

void main() {
    // write a single triangle in clip/world coordinates (choose positions visible to camera)
    uint idx = atomicAdd(vertexCounter, 3u);
    verts[idx+0].pos = vec4(-1.0, -1.0, 0.0, 1.0);
    verts[idx+0].normal = vec4(0,0,1,0);
    verts[idx+0].color = vec4(1,0,0,1);

    verts[idx+1].pos = vec4(1.0, -1.0, 0.0, 1.0);
    verts[idx+1].normal = vec4(0,0,1,0);
    verts[idx+1].color = vec4(0,1,0,1);

    verts[idx+2].pos = vec4(0.0, 1.0, 0.0, 1.0);
    verts[idx+2].normal = vec4(0,0,1,0);
    verts[idx+2].color = vec4(0,0,1,1);
}